rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /games/{gameId} {
      allow read, write: if request.auth != null;
    }
    match /results/{resultId} {
      allow read, write: if request.auth != null;
    }
    match /pongGames/{gameId} {
      allow read, write: if request.auth != null;
    }
    match /vierGames/{gameId} {
      allow read, write: if request.auth != null;
    }
    match /brandungGames/{gameId} {
      allow read, write: if request.auth != null;
    }
    match /brandungResults/{resultId} {
      allow read, write: if request.auth != null;
    }
    match /meermauGames/{gameId} {
      allow read, write: if request.auth != null;
    }
    match /meermauResults/{resultId} {
      allow read, write: if request.auth != null;
    }
    match /usernames/{name} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
