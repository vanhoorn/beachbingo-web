rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Username → email lookup: publicly readable so unauthenticated users
    // can resolve a display name to an email before signing in.
    // Writing is restricted to authenticated users (happens during registration).
    match /usernameMap/{username} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // All other collections require authentication.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
